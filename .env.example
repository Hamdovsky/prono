# ============================================================
#  TITANIUM AI — Variables d'Environnement DOCKER
#  Copier ce fichier en .env et remplir les valeurs réelles
# ============================================================

# ── SERVEUR NODE ────────────────────────────────────────────
PORT=3001
NODE_ENV=production
API_SECRET_KEY=CHANGER_MOI_CLEF_SECRETE_LONGUE_256BIT

# ── BASE DE DONNÉES PostgreSQL / TimescaleDB ─────────────────
DB_HOST=postgres-timescale
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=titanium_pass
DB_NAME=titanium_quant

# ── REDIS CACHE ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=titanium_redis
REDIS_URL=redis://:titanium_redis@redis:6379

# ── FASTAPI ML ENGINE ────────────────────────────────────────
INFERENCE_URL=http://fastapi-ml:8000
PYTHON_PATH=/usr/bin/python3

# ── BOT TELEGRAM ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_BOT
TELEGRAM_CHAT_ID=VOTRE_CHAT_ID

# ── OPTIONS SYSTÈME ──────────────────────────────────────────
DISABLE_BACKUP=false
FRONTEND_URL=*

# Football APIs
FOOTBALLDATA_ENABLED=true
FOOTBALLDATA_KEY=VOTRE_FOOTBALLDATA_KEY
FOOTBALLDATA_HOST=footballdata.io
FOOTBALLDATA_DAILY_LIMIT=20

RAPIDAPI_ENABLED=true
RAPIDAPI_KEY=VOTRE_RAPIDAPI_KEY
RAPIDAPI_HOST=sportapi7.p.rapidapi.com
RAPIDAPI_DAILY_LIMIT=20

VITE_API_URL=https://prono-l5e3.onrender.com

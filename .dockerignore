# ============================================================
# TITANIUM SYSTEM — .dockerignore
# ============================================================

# Node
node_modules/
npm-debug.log*
bun.lock

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Git
.git/
.gitignore
.github/

# IDE
.vscode/
.idea/

# Secrets (never in image)
.env
.env.*
!.env.example

# Databases (volumes gèrent les données persistantes)
*.db
*.sqlite
*.sqlite3

# Logs (volume monté)
logs/
*.log
ai_server_startup.log
replay_pid*.log
hs_err_pid*.log

# Dev / test
scratch/
__tests__/
__mocks__/
tests/
coverage/
.dockerignore

# Debug / dump files
*.html
*.png
debug_*
betslip_*
bibeet_*
africanobet_*
promosport_*
shadow_*
betx2_*

# Archives / backups
archive/
backups/
tmp/

# Build artifacts
dist_test/
# Note: dist/ is intentionally NOT ignored — Node container needs it

# Android
android/

# Misc
research/
reports/
k8s/
$null
0.6
